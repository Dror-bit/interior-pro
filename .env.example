# Path to LibreDWG dwg2dxf executable (recommended for DWG support, free & open-source)
# Install: https://github.com/LibreDWG/libredwg/releases
# Linux: sudo apt install libredwg-tools  |  macOS: brew install libredwg
LIBREDWG_PATH=

# Path to ODA File Converter executable (fallback for DWG, required for CAD-PDF conversion)
ODA_CONVERTER_PATH=

# Upload directory (default: ./uploads)
UPLOAD_DIR=./uploads

# Default wall height in mm
DEFAULT_WALL_HEIGHT=2700

# Default wall thickness in mm
DEFAULT_WALL_THICKNESS=150
