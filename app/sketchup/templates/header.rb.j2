# =============================================================
# Generated by Interior-Pro
# Source: {{ source_filename }}
# Date: {{ timestamp }}
# Units: {{ units }}
# Walls: {{ wall_count }} | Openings: {{ opening_count }} | Furniture: {{ furniture_count }}
# =============================================================

model = Sketchup.active_model
model.start_operation('Import Floor Plan - {{ source_filename }}', true)
entities = model.active_entities

# Set units
{% if units == "mm" %}
model.options["UnitsOptions"]["LengthUnit"] = 2
{% elif units == "cm" %}
model.options["UnitsOptions"]["LengthUnit"] = 3
{% elif units == "m" %}
model.options["UnitsOptions"]["LengthUnit"] = 4
{% elif units == "inches" %}
model.options["UnitsOptions"]["LengthUnit"] = 0
{% elif units == "feet" %}
model.options["UnitsOptions"]["LengthUnit"] = 1
{% endif %}

# Unit conversion factor to inches (SketchUp internal unit)
{% if units == "mm" %}
SCALE = 1.0 / 25.4
{% elif units == "cm" %}
SCALE = 1.0 / 2.54
{% elif units == "m" %}
SCALE = 1.0 / 0.0254
{% elif units == "inches" %}
SCALE = 1.0
{% elif units == "feet" %}
SCALE = 12.0
{% endif %}

def sp(v)
  v * SCALE
end

# Create layers
{% for layer_name in layers %}
model.layers.add('{{ layer_name }}')
{% endfor %}
